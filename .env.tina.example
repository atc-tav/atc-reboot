# TinaCMS — copy the relevant vars to .env.local.
#
# For LOCAL editing (`pnpm tina`) you need NOTHING here — Tina runs a local
# content server over the filesystem.
#
# For the DEPLOYED editor (so the content consultant can log in at /admin on the
# live site), create a free project at https://app.tina.io, connect this GitHub
# repo, and paste the values below. Content is still committed to git by Tina.

# Public — identifies your Tina Cloud project.
NEXT_PUBLIC_TINA_CLIENT_ID=

# Secret — a read/write token from the same project. Keep this out of git.
TINA_TOKEN=

# Which branch Tina reads/writes. Defaults to the deploy branch, else "main".
# NEXT_PUBLIC_TINA_BRANCH=main
